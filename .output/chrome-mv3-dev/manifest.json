{
  "manifest_version": 3,
  "name": "序言",
  "description": "简洁高效的新标签页",
  "version": "0.1.0",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png",
    "180": "icon/180.png",
    "192": "icon/192.png",
    "512": "icon/512.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://*.google.com/*",
    "https://*.gstatic.com/*",
    "https://favicon.im/*",
    "https://icons.duckduckgo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Default Popup Title",
    "default_popup": "popup.html"
  }
}