{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git check-ignore -q .worktrees)",
      "Bash(pnpm compile)",
      "Bash(git commit:*)",
      "mcp__playwright__*"
    ],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "url",
        "url": "https://raw.githubusercontent.com/obra/superpowers-marketplace/refs/heads/main/.claude-plugin/marketplace.json"
      }
    }
  }
}
